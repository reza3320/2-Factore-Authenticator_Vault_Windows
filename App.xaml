<Application x:Class="Win2FA.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             DispatcherUnhandledException="Application_DispatcherUnhandledException">
    <Application.Resources>
         <!-- Fluid Fluent Dark Theme Resources -->
         <SolidColorBrush x:Key="BgBrush" Color="#0B0B0F"/>
         <SolidColorBrush x:Key="CardBgBrush" Color="#12121A"/>
         <SolidColorBrush x:Key="BorderBrush" Color="#22222F"/>
         <SolidColorBrush x:Key="AccentBrush" Color="#DAA520"/>
         <SolidColorBrush x:Key="AccentHoverBrush" Color="#B8860B"/>
         <SolidColorBrush x:Key="TextBrush" Color="#ECECEF"/>
         <SolidColorBrush x:Key="MutedTextBrush" Color="#8F8F9F"/>
    </Application.Resources>
</Application>
