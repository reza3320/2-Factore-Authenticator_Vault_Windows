<Window x:Class="Win2FA.TrayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayWindow" Height="380" Width="260"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Deactivated="Window_Deactivated">
    <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Head -->
            <TextBlock Grid.Row="0" Text="OFFLINE AUTHENTICATOR" FontSize="11" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" Margin="0,0,0,10" HorizontalAlignment="Center"/>

            <!-- Keys List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TrayKeysItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="10" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Cursor="Hand" MouseLeftButtonUp="TrayCard_MouseLeftButtonUp" ToolTip="Click to copy code">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Issuer}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding AccountName}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Code}" FontSize="18" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" FontFamily="Consolas"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Bottom Progress -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SecondsText" Text="30s" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" FontFamily="Consolas" VerticalAlignment="Center"/>
                <ProgressBar x:Name="TrayProgressBar" Grid.Column="1" Height="3" Maximum="30" Value="30" Foreground="{DynamicResource AccentBrush}" Background="#1F1F2E" BorderThickness="0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
